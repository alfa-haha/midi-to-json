{% include "snippets/pro-panel.html" %}

{# Tool pages: embed the exact panel copy inline so "On this page" renders even if pro-copy.json fetch fails. #}
{% if toolId and proCopy and proCopy.toolById and proCopy.toolById[toolId] %}
  {% set panelCfg = (proCopy.panel[lang] if proCopy.panel and proCopy.panel[lang] else proCopy.panel.en) %}
  {% set globalItems = (proCopy.globalBenefits[lang] if proCopy.globalBenefits and proCopy.globalBenefits[lang] else proCopy.globalBenefits.en) %}
  {% set tool = proCopy.toolById[toolId] %}
  {% set toolItems = (tool.proBenefits[lang] if tool.proBenefits and tool.proBenefits[lang] else tool.proBenefits.en) %}
  <script type="application/json" id="midieasy-pro-panel-copy">
    {{ { toolId: toolId, lang: lang, panel: panelCfg, globalBenefits: globalItems, toolBenefits: toolItems } | dump | safe }}
  </script>
{% endif %}
