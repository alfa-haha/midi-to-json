<div class="converter-container">
  <h2>{{ toolTitle }}</h2>
  <p style="color:#666;">This page is available as a static landing page in MVP. The converter UI will be enabled in a later phase.</p>
  <div class="upload-container" aria-disabled="true" style="opacity:0.6; pointer-events:none;">
    <div class="drop-area">
      <i class="fas fa-cloud-upload-alt upload-icon"></i>
      <h3>Drop files here</h3>
      <p>or</p>
      <label class="file-input-label">Select files</label>
    </div>
    <div class="action-buttons">
      <button class="btn primary-btn" disabled>Convert</button>
      <button class="btn secondary-btn" disabled>Download</button>
    </div>
  </div>
</div>

