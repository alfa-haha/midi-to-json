<h2>{{ toolTitle }}</h2>
<p style="color:#666;">This page is available as a static landing page in MVP. The converter UI will be enabled in a later phase.</p>

<div class="upload-area" id="drop-area" aria-disabled="true" style="opacity:0.6; pointer-events:none;">
  <div class="upload-icon">
    <i class="fas fa-file-upload"></i>
  </div>
  <h3>Drop files here</h3>
  <p>or</p>
  <label for="file-input" class="file-input-label">Select files</label>
  <input type="file" id="file-input" multiple hidden disabled />
  <p class="file-limit-info"><i class="fas fa-info-circle"></i> For best performance, limit to 20 files (max 100MB total)</p>
  <p class="file-info">No files selected</p>
</div>

<div class="action-buttons">
  <button class="btn primary-btn" disabled>Convert</button>
  <button class="btn secondary-btn" disabled>Download</button>
</div>
