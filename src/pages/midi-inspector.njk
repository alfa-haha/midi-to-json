bodyScripts: |
  <script src="/js/midi-inspector.bundle.js" defer></script>
  <script>
    document.addEventListener("DOMContentLoaded", () => {
      const pushDataLayerEvent = (eventName, params = {}) => {
        if (!eventName) return;
        try {
          const payload = { event: eventName, tool: "midi-inspector", page_path: globalThis.location ? globalThis.location.pathname : "", ...params };
          globalThis.dataLayer = globalThis.dataLayer || [];
          globalThis.dataLayer.push(payload);
        } catch {
          // no-op
        }
      };

      const faqRoot = document.getElementById("inspector-faq-accordion");
      if (faqRoot) {
        const faqItems = Array.from(faqRoot.querySelectorAll(".accordion-item"));
        faqItems.forEach((item) => {
          const header = item.querySelector(".accordion-header");
          if (!header) return;

          const syncExpanded = () => {
            const expanded = item.classList.contains("active");
            header.setAttribute("aria-expanded", expanded ? "true" : "false");
          };

          const toggle = () => {
            const isActive = item.classList.contains("active");
            faqItems.forEach((other) => {
              other.classList.remove("active");
              const otherHeader = other.querySelector(".accordion-header");
              if (otherHeader) otherHeader.setAttribute("aria-expanded", "false");
            });
            if (!isActive) item.classList.add("active");
            syncExpanded();
          };

          header.addEventListener("click", toggle);
          header.addEventListener("keydown", (e) => {
            if (e.key !== "Enter" && e.key !== " ") return;
            e.preventDefault();
            toggle();
          });

          syncExpanded();
        });
      }

      const shotCards = Array.from(document.querySelectorAll(".inspector-shot-card"));
      if (shotCards.length) {
        const items = shotCards
          .map((card, index) => {
            const media = card.querySelector(".inspector-shot-media");
            const img = card.querySelector("img");
            const cap = card.querySelector(".inspector-shot-caption");
            if (!media || !img || !img.getAttribute("src")) return null;
            const caption = cap ? cap.textContent.trim() : `Image ${index + 1}`;
            media.setAttribute("role", "button");
            media.setAttribute("tabindex", "0");
            media.setAttribute("aria-label", `Open image: ${caption}`);
            return {
              media,
              src: img.getAttribute("src"),
              alt: img.getAttribute("alt") || caption,
              caption
            };
          })
          .filter(Boolean);

        if (items.length) {
          const lightbox = document.createElement("div");
          lightbox.className = "inspector-lightbox";
          lightbox.setAttribute("aria-hidden", "true");
          lightbox.innerHTML = `
            <div class="inspector-lightbox__dialog" role="dialog" aria-modal="true" aria-label="Inspection image preview" tabindex="-1">
              <button type="button" class="inspector-lightbox__close" aria-label="Close image preview">✕</button>
              <button type="button" class="inspector-lightbox__nav inspector-lightbox__nav--prev" aria-label="Previous image">‹</button>
              <button type="button" class="inspector-lightbox__nav inspector-lightbox__nav--next" aria-label="Next image">›</button>
              <div class="inspector-lightbox__stage">
                <img class="inspector-lightbox__img" src="" alt="" />
              </div>
              <div class="inspector-lightbox__footer">
                <p class="inspector-lightbox__caption"></p>
                <div class="inspector-lightbox__count"></div>
              </div>
            </div>
          `;
          document.body.appendChild(lightbox);

          const dialog = lightbox.querySelector(".inspector-lightbox__dialog");
          const closeBtn = lightbox.querySelector(".inspector-lightbox__close");
          const prevBtn = lightbox.querySelector(".inspector-lightbox__nav--prev");
          const nextBtn = lightbox.querySelector(".inspector-lightbox__nav--next");
          const lightboxImg = lightbox.querySelector(".inspector-lightbox__img");
          const captionEl = lightbox.querySelector(".inspector-lightbox__caption");
          const countEl = lightbox.querySelector(".inspector-lightbox__count");

          let currentIndex = 0;
          let lastFocused = null;

          const renderLightbox = () => {
            const item = items[currentIndex];
            if (!item || !lightboxImg || !captionEl || !countEl) return;
            lightboxImg.setAttribute("src", item.src);
            lightboxImg.setAttribute("alt", item.alt);
            captionEl.textContent = item.caption;
            countEl.textContent = `${currentIndex + 1} / ${items.length}`;
          };

          const openLightbox = (index, triggerEl) => {
            currentIndex = index;
            lastFocused = triggerEl || null;
            renderLightbox();
            lightbox.classList.add("is-open");
            lightbox.setAttribute("aria-hidden", "false");
            document.body.style.overflow = "hidden";
            if (dialog) dialog.focus();
          };

          const closeLightbox = () => {
            lightbox.classList.remove("is-open");
            lightbox.setAttribute("aria-hidden", "true");
            document.body.style.overflow = "";
            if (lastFocused && typeof lastFocused.focus === "function") lastFocused.focus();
          };

          const moveLightbox = (delta) => {
            currentIndex = (currentIndex + delta + items.length) % items.length;
            renderLightbox();
          };

          items.forEach((item, index) => {
            item.media.addEventListener("click", () => openLightbox(index, item.media));
            item.media.addEventListener("keydown", (e) => {
              if (e.key !== "Enter" && e.key !== " ") return;
              e.preventDefault();
              openLightbox(index, item.media);
            });
          });

          if (closeBtn) closeBtn.addEventListener("click", closeLightbox);
          if (prevBtn) prevBtn.addEventListener("click", () => moveLightbox(-1));
          if (nextBtn) nextBtn.addEventListener("click", () => moveLightbox(1));
          lightbox.addEventListener("click", (e) => {
            if (e.target === lightbox) closeLightbox();
          });

          document.addEventListener("keydown", (e) => {
            if (!lightbox.classList.contains("is-open")) return;
            if (e.key === "Escape") {
              e.preventDefault();
              closeLightbox();
              return;
            }
            if (e.key === "ArrowLeft") {
              e.preventDefault();
              moveLightbox(-1);
              return;
            }
            if (e.key === "ArrowRight") {
              e.preventDefault();
              moveLightbox(1);
            }
          });
        }
      }

      document.querySelectorAll("#inspector-tabs .inspector-tab[data-tab]").forEach((btn) => {
        btn.addEventListener("click", () => {
          const tab = btn.getAttribute("data-tab") || "";
          pushDataLayerEvent("inspector_tab_switch", { tab });
        });
      });

      document.querySelectorAll("a[data-track-event]").forEach((link) => {
        link.addEventListener("click", () => {
          const eventName = link.getAttribute("data-track-event");
          if (!eventName) return;
          pushDataLayerEvent(eventName, {
            target_path: link.getAttribute("href") || "",
            cta: link.getAttribute("data-cta") || "",
            section: link.getAttribute("data-section") || ""
          });
        });
      });
    });
  </script>
