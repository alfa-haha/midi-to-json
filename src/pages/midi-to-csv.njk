bodyScripts: |
  <script src="/js/midi-to-csv.bundle.js" defer></script>
  <script>
    document.addEventListener("DOMContentLoaded", () => {
      const copyBtn = document.getElementById("csv-copy-example-btn");
      const exampleBlock = document.getElementById("csv-example-block");
      if (copyBtn && exampleBlock) {
        const text = exampleBlock.textContent ? String(exampleBlock.textContent).trim() : "";
        copyBtn.addEventListener("click", async () => {
          if (!text) return;
          try {
            if (navigator.clipboard && navigator.clipboard.writeText) {
              await navigator.clipboard.writeText(text);
            } else {
              const ta = document.createElement("textarea");
              ta.value = text;
              ta.setAttribute("readonly", "");
              ta.style.position = "absolute";
              ta.style.left = "-9999px";
              document.body.appendChild(ta);
              ta.select();
              document.execCommand("copy");
              ta.remove();
            }
            const original = copyBtn.textContent;
            copyBtn.textContent = "Copied";
            setTimeout(() => {
              copyBtn.textContent = original || "Copy CSV";
            }, 1200);
          } catch {
            // no-op
          }
        });
      }

      const root = document.getElementById("csv-faq-accordion");
      if (!root) return;

      const items = Array.from(root.querySelectorAll(".accordion-item"));
      items.forEach((item) => {
        const header = item.querySelector(".accordion-header");
        if (!header) return;

        const syncExpanded = () => {
          const expanded = item.classList.contains("active");
          header.setAttribute("aria-expanded", expanded ? "true" : "false");
        };

        const toggle = () => {
          const isActive = item.classList.contains("active");
          items.forEach((other) => {
            other.classList.remove("active");
            const otherHeader = other.querySelector(".accordion-header");
            if (otherHeader) otherHeader.setAttribute("aria-expanded", "false");
          });
          if (!isActive) item.classList.add("active");
          syncExpanded();
        };

        header.addEventListener("click", toggle);
        header.addEventListener("keydown", (e) => {
          if (e.key !== "Enter" && e.key !== " ") return;
          e.preventDefault();
          toggle();
        });

        syncExpanded();
      });
    });
  </script>
